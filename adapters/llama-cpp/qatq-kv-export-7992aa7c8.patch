+bool qatq_tensor_is_gpu_resident(const ggml_tensor * tensor) {
+    return tensor != nullptr &&
+        tensor->buffer != nullptr &&
+        !ggml_backend_buft_is_host(ggml_backend_buffer_get_type(tensor->buffer));
+}
