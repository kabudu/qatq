+void qatq_checksum_update(uint64_t & checksum, const uint8_t * data, size_t size) {
+    for (size_t i = 0; i < size; ++i) {
+        checksum ^= data[i];
+        checksum *= 1099511628211ULL;
+    }
+}
+
+bool qatq_write_tensor_slice(std::ofstream & out, const ggml_tensor * tensor, size_t offset, size_t size, uint64_t * checksum) {
+    std::vector<uint8_t> buf(size);
+    ggml_backend_tensor_get(tensor, buf.data(), offset, size);
+    if (checksum != nullptr) {
+        qatq_checksum_update(*checksum, buf.data(), buf.size());
+    }
+    out.write(reinterpret_cast<const char *>(buf.data()), static_cast<std::streamsize>(buf.size()));
+    return out.good();
+}
+
+std::vector<uint8_t> qatq_read_tensor_slice(const ggml_tensor * tensor, size_t offset, size_t size, uint64_t * checksum) {
+    std::vector<uint8_t> buf(size);
+    ggml_backend_tensor_get(tensor, buf.data(), offset, size);
+    if (checksum != nullptr) {
+        qatq_checksum_update(*checksum, buf.data(), buf.size());
+    }
+    return buf;
+}
+
+void qatq_write_tensor_bytes(ggml_tensor * tensor, size_t offset, const std::vector<uint8_t> & bytes) {
+    ggml_backend_tensor_set(tensor, bytes.data(), offset, bytes.size());
+}
+
+bool qatq_tensor_slice_equals(const ggml_tensor * tensor, size_t offset, const std::vector<uint8_t> & expected) {
+    std::vector<uint8_t> actual(expected.size());
+    ggml_backend_tensor_get(tensor, actual.data(), offset, actual.size());
+    return actual == expected;
+}
