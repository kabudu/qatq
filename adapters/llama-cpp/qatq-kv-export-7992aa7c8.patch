+        const char *                 model_id,
+        int64_t                      current_token) {
+    const llama_kv_cache * kv = llama_qatq_get_kv_cache(ctx);
+    return kv != nullptr && dir != nullptr && kv->export_qatq_tensors(dir, seq_id, trace_path, model_id, current_token);
