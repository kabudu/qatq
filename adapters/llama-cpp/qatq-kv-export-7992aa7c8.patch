+static bool qatq_parse_qcur_layer(const char * name, int * layer_out) {
+    const char prefix[] = "Qcur-";
+    if (strncmp(name, prefix, sizeof(prefix) - 1) != 0) {
+        return false;
+    }
+    const char * cursor = name + sizeof(prefix) - 1;
+    if (*cursor == '\0') {
+        return false;
+    }
+    errno = 0;
+    char * end = nullptr;
+    const long parsed = strtol(cursor, &end, 10);
+    if (errno != 0 || end == cursor || *end != '\0' || parsed < 0 || parsed > std::numeric_limits<int>::max()) {
+        return false;
+    }
+    *layer_out = static_cast<int>(parsed);
+    return true;
+}
+
+static bool qatq_attention_fixture_has_layer(const qatq_attention_fixture_state & state, int layer) {
+    for (const auto & record : state.records) {
+        if (record.layer == layer) {
+            return true;
+        }
+    }
+    return false;
+}
+
+static int qatq_attention_fixture_layer_count(const qatq_attention_fixture_state & state) {
+    std::vector<int> layers;
+    for (const auto & record : state.records) {
+        bool seen = false;
+        for (int layer : layers) {
+            if (layer == record.layer) {
+                seen = true;
+                break;
+            }
+        }
+        if (!seen) {
+            layers.push_back(record.layer);
+        }
+    }
+    return static_cast<int>(layers.size());
+}
+
+static bool qatq_attention_fixture_is_candidate(const ggml_tensor * tensor, const qatq_attention_fixture_state & state, int * layer_out) {
+    int layer = -1;
+    if (!qatq_parse_qcur_layer(tensor->name, &layer)) {
+        return false;
+    }
+    if (qatq_attention_fixture_has_layer(state, layer)) {
+        return false;
+    }
+    if (qatq_attention_fixture_layer_count(state) >= state.max_layers) {
+        return false;
+    }
+    if (tensor->type != GGML_TYPE_F32) {
+        return false;
+    }
+    if (tensor->ne[0] <= 0 || tensor->ne[1] <= 0 || tensor->ne[2] <= 1) {
+        return false;
+    }
+    *layer_out = layer;
+    return true;
+}
+
+static bool qatq_attention_fixture_eval_cb(ggml_tensor * tensor, bool ask, void * user_data) {
+    auto * state = static_cast<qatq_attention_fixture_state *>(user_data);
+    if (state == nullptr || state->dir.empty()) {
+        return true;
+    }
+    if (state->failed) {
+        return false;
+    }
+
+    int layer = -1;
+    const bool candidate = qatq_attention_fixture_is_candidate(tensor, *state, &layer);
+    if (ask) {
+        return candidate;
+    }
+    if (!candidate) {
+        return true;
+    }
+    if (tensor->nb[0] != static_cast<int64_t>(sizeof(float))) {
+        state->failed = true;
+        state->error = "QATQ attention fixture export requires contiguous f32 head dimensions";
+        return false;
+    }
+
+    std::error_code ec;
+    std::filesystem::path dir(state->dir);
+    std::filesystem::create_directories(dir, ec);
+    if (ec) {
+        state->failed = true;
+        state->error = "failed to create attention fixture directory: " + ec.message();
+        return false;
+    }
+
+    const int64_t head_dim = tensor->ne[0];
+    const int64_t heads = tensor->ne[1];
+    const int64_t token_index = tensor->ne[2] - 1;
+    const size_t size = static_cast<size_t>(head_dim) * sizeof(float);
+    for (int64_t head = 0; head < heads; ++head) {
+        const size_t offset = static_cast<size_t>(head * tensor->nb[1] + token_index * tensor->nb[2]);
+        std::vector<float> query(static_cast<size_t>(head_dim));
+        ggml_backend_tensor_get(tensor, query.data(), offset, size);
+
+        const std::string file = "query_l" + std::to_string(layer) + "_h" + std::to_string(head) + "_last.f32le";
+        std::ofstream out(dir / file, std::ios::binary);
+        if (!out) {
+            state->failed = true;
+            state->error = "failed to create attention fixture query file";
+            return false;
+        }
+        out.write(reinterpret_cast<const char *>(query.data()), static_cast<std::streamsize>(size));
+        if (!out.good()) {
+            state->failed = true;
+            state->error = "failed to write attention fixture query file";
+            return false;
+        }
+
+        state->records.push_back(qatq_attention_fixture_record{layer, head, head_dim, heads, token_index, file});
+    }
+    return true;
+}
+
+static bool qatq_write_attention_fixture_manifest(
+        const std::string & dir,
+        const std::vector<qatq_attention_fixture_record> & records) {
+    std::ofstream out(std::filesystem::path(dir) / "attention-fixture.json", std::ios::binary);
+    if (!out) {
+        return false;
+    }
+    out << "{\n";
+    out << "  \"format\": \"qatq-llama-cpp-attention-fixture-v1\",\n";
+    out << "  \"query_dtype\": \"f32\",\n";
+    out << "  \"records\": [\n";
+    for (size_t i = 0; i < records.size(); ++i) {
+        const auto & record = records[i];
+        if (i > 0) {
+            out << ",\n";
+        }
+        out << "    {\"layer\":" << record.layer
+            << ",\"head\":" << record.head
+            << ",\"head_dim\":" << record.head_dim
+            << ",\"heads\":" << record.heads
+            << ",\"token_index\":" << record.token_index
+            << ",\"query_file\":\"";
+        qatq_write_json_escaped(out, record.file);
+        out << "\"}";
+    }
+    out << "\n  ]\n";
+    out << "}\n";
+    return static_cast<bool>(out);
+}
