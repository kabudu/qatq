+struct qatq_segmented_kqv_kernel_args {
+    uint32_t head_dim;
+    uint32_t n_query_heads;
+    uint32_t n_kv_heads;
+    uint32_t n_queries;
+    uint32_t n_pages;
+    uint32_t total_tokens;
+    uint32_t max_page_tokens;
+    uint32_t max_total_tokens;
+    uint32_t k_stride_dim;
+    uint32_t k_stride_head;
+    uint32_t k_stride_token;
+    uint32_t k_stride_page;
+    uint32_t v_stride_dim;
+    uint32_t v_stride_head;
+    uint32_t v_stride_token;
+    uint32_t v_stride_page;
+    uint32_t mask_is_f16;
+    float    scale;
+};
+
+// QATQ segmented K/Q/V online page-summary attention kernel target.
+//
+// This is the first accelerator source for the backend-scheduled route. Each
+// thread computes one output element and applies the stable online softmax
+// recurrence across bounded K/V pages without materialising concatenated logits
+// or a full logical K/V tensor.
+static inline float qatq_bf16_to_f32(ushort value) {
+    return as_type<float>((uint32_t(value)) << 16);
+}
+
+static inline float qatq_kv_to_f32(float value) {
+    return value;
+}
+
+static inline float qatq_kv_to_f32(half value) {
+    return float(value);
+}
+
+static inline float qatq_kv_to_f32(ushort value) {
+    return qatq_bf16_to_f32(value);
+}
+
+static inline float qatq_segmented_kqv_mask_value(
+        device const char * mask,
+        constant qatq_segmented_kqv_kernel_args & args,
+        uint32_t offset) {
+    return args.mask_is_f16 != 0u ? float(((device const half *) mask)[offset]) : ((device const float *) mask)[offset];
+}
+
+static inline uint32_t qatq_segmented_kqv_page_for_token(
+        constant qatq_segmented_kqv_kernel_args & args,
+        device const uint32_t * page_token_offsets,
+        uint32_t token) {
+    uint32_t page = 0;
+    while (page + 1u < args.n_pages && token >= page_token_offsets[page + 1u]) {
+        ++page;
+    }
+    return page;
+}
+
+template<typename T>
+static inline void qatq_segmented_kqv_group_impl(
+        constant qatq_segmented_kqv_kernel_args & args,
+        device const float * q,
+        device const T * k,
+        device const T * v,
+        device const uint32_t * page_token_offsets,
+        device const uint32_t * token_page_table,
+        device const uint32_t * token_local_table,
+        device const char * mask,
+        device float * dst,
+        threadgroup float * shared,
+        uint3 tgpig,
+        uint3 tpitg,
+        uint3 ntg) {
+    const uint tid = tpitg.x;
+    const uint nth = ntg.x;
+    const uint32_t query_head = tgpig.x;
+    const uint32_t query_idx  = tgpig.y;
+
+    if (query_head >= args.n_query_heads || query_idx >= args.n_queries) {
+        return;
+    }
+    if (args.n_pages == 0 || args.head_dim == 0 || args.n_kv_heads == 0) {
+        return;
+    }
+
+    const uint32_t total_tokens = args.total_tokens;
+    if (total_tokens == 0 || total_tokens > args.max_total_tokens || page_token_offsets[args.n_pages] != total_tokens) {
+        return;
+    }
+
+    const uint32_t kv_group = args.n_query_heads / args.n_kv_heads;
+    if (kv_group == 0u) {
+        return;
+    }
+    const uint32_t kv_head = query_head / kv_group;
+    if (kv_head >= args.n_kv_heads) {
+        return;
+    }
+    const uint32_t q_base = (query_head*args.n_queries + query_idx)*args.head_dim;
+    const uint32_t out_base = (query_idx*args.n_query_heads + query_head)*args.head_dim;
+
+    threadgroup float * logits = shared;
+    threadgroup float * scratch = shared + total_tokens;
+
+    if (tid == 0u) {
+        scratch[0] = 0.0f;
+        uint32_t prev_end = 0;
+        for (uint32_t page = 0; page < args.n_pages; ++page) {
+            const uint32_t token_begin = page_token_offsets[page];
+            const uint32_t token_end   = page_token_offsets[page + 1];
+            if (token_begin != prev_end || token_end < token_begin || token_end - token_begin > args.max_page_tokens) {
+                scratch[0] = 1.0f;
+            }
+            prev_end = token_end;
+        }
+        if (prev_end != total_tokens) {
+            scratch[0] = 1.0f;
+        }
+    }
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+    if (scratch[0] != 0.0f) {
+        return;
+    }
+
+    float local_max = -INFINITY;
+    for (uint32_t token = tid; token < total_tokens; token += nth) {
+        const uint32_t page = token_page_table[token];
+        const uint32_t local_token = token_local_table[token];
+        if (page >= args.n_pages || local_token >= args.max_page_tokens ||
+                local_token >= page_token_offsets[page + 1u] - page_token_offsets[page]) {
+            logits[token] = -INFINITY;
+            local_max = max(local_max, logits[token]);
+            continue;
+        }
+        const uint32_t k_base = page*args.k_stride_page + local_token*args.k_stride_token + kv_head*args.k_stride_head;
+        float logit = 0.0f;
+        for (uint32_t d = 0; d < args.head_dim; ++d) {
+            logit += q[q_base + d] * qatq_kv_to_f32(k[k_base + d*args.k_stride_dim]);
+        }
+        logit = logit*args.scale + qatq_segmented_kqv_mask_value(mask, args, query_idx*total_tokens + token);
+        logits[token] = logit;
+        local_max = max(local_max, logit);
+    }
+
+    scratch[tid] = local_max;
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+    for (uint32_t stride = nth >> 1u; stride > 0u; stride >>= 1u) {
+        if (tid < stride) {
+            scratch[tid] = max(scratch[tid], scratch[tid + stride]);
+        }
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+    }
+    const float max_logit = scratch[0];
+
+    float local_denom = 0.0f;
+    for (uint32_t token = tid; token < total_tokens; token += nth) {
+        const float weight = exp(logits[token] - max_logit);
+        logits[token] = weight;
+        local_denom += weight;
+    }
+
+    scratch[tid] = local_denom;
+    threadgroup_barrier(mem_flags::mem_threadgroup);
+    for (uint32_t stride = nth >> 1u; stride > 0u; stride >>= 1u) {
+        if (tid < stride) {
+            scratch[tid] += scratch[tid + stride];
+        }
+        threadgroup_barrier(mem_flags::mem_threadgroup);
+    }
+    const float denom = scratch[0];
+
+    for (uint32_t dim = tid; dim < args.head_dim; dim += nth) {
+        float acc = 0.0f;
+        if (denom > 0.0f) {
+            for (uint32_t page = 0; page < args.n_pages; ++page) {
+                const uint32_t token_begin = page_token_offsets[page];
+                const uint32_t token_end = page_token_offsets[page + 1u];
+                const uint32_t v_page_base = page*args.v_stride_page + kv_head*args.v_stride_head + dim*args.v_stride_dim;
+                for (uint32_t token = token_begin; token < token_end; ++token) {
+                    const uint32_t local_token = token - token_begin;
+                    acc += logits[token]*qatq_kv_to_f32(v[v_page_base + local_token*args.v_stride_token]);
+                }
+            }
+            acc /= denom;
+        }
+        dst[out_base + dim] = acc;
+    }
+}
+
+kernel void kernel_qatq_segmented_kqv_f32(
+        constant qatq_segmented_kqv_kernel_args & args,
+        device const float * q,
+        device const float * k,
+        device const float * v,
+        device const uint32_t * page_token_offsets,
+        device const uint32_t * token_page_table,
+        device const uint32_t * token_local_table,
+        device const char * mask,
+        device float * dst,
+        threadgroup float * shared [[threadgroup(0)]],
+        uint3 tgpig [[threadgroup_position_in_grid]],
+        uint3 tpitg [[thread_position_in_threadgroup]],
+        uint3 ntg [[threads_per_threadgroup]]) {
+    qatq_segmented_kqv_group_impl(args, q, k, v, page_token_offsets, token_page_table, token_local_table, mask, dst, shared, tgpig, tpitg, ntg);
+}
+
+kernel void kernel_qatq_segmented_kqv_f16(
+        constant qatq_segmented_kqv_kernel_args & args,
+        device const float * q,
+        device const half * k,
+        device const half * v,
+        device const uint32_t * page_token_offsets,
+        device const uint32_t * token_page_table,
+        device const uint32_t * token_local_table,
+        device const char * mask,
+        device float * dst,
+        threadgroup float * shared [[threadgroup(0)]],
+        uint3 tgpig [[threadgroup_position_in_grid]],
+        uint3 tpitg [[thread_position_in_threadgroup]],
+        uint3 ntg [[threads_per_threadgroup]]) {
+    qatq_segmented_kqv_group_impl(args, q, k, v, page_token_offsets, token_page_table, token_local_table, mask, dst, shared, tgpig, tpitg, ntg);
+}
+
+kernel void kernel_qatq_segmented_kqv_bf16(
+        constant qatq_segmented_kqv_kernel_args & args,
+        device const float * q,
+        device const ushort * k,
+        device const ushort * v,
+        device const uint32_t * page_token_offsets,
+        device const uint32_t * token_page_table,
+        device const uint32_t * token_local_table,
+        device const char * mask,
+        device float * dst,
+        threadgroup float * shared [[threadgroup(0)]],
+        uint3 tgpig [[threadgroup_position_in_grid]],
+        uint3 tpitg [[thread_position_in_threadgroup]],
+        uint3 ntg [[threads_per_threadgroup]]) {
+    qatq_segmented_kqv_group_impl(args, q, k, v, page_token_offsets, token_page_table, token_local_table, mask, dst, shared, tgpig, tpitg, ntg);
+}
