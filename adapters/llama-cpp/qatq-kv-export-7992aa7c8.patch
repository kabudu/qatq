+static uint64_t qatq_fnv1a64(const std::string & text) {
+    uint64_t hash = 14695981039346656037ULL;
+    for (unsigned char byte : text) {
+        hash ^= byte;
+        hash *= 1099511628211ULL;
+    }
+    return hash;
+}
