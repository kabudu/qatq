+void qatq_write_json_escaped(std::ofstream & out, const std::string & text) {
+    for (unsigned char ch : text) {
+        switch (ch) {
+            case '\\': out << "\\\\"; break;
+            case '"':  out << "\\\""; break;
+            case '\b': out << "\\b"; break;
+            case '\f': out << "\\f"; break;
+            case '\n': out << "\\n"; break;
+            case '\r': out << "\\r"; break;
+            case '\t': out << "\\t"; break;
+            default:
+                if (ch < 0x20) {
+                    static const char hex[] = "0123456789abcdef";
+                    out << "\\u00" << hex[ch >> 4] << hex[ch & 0x0f];
+                } else {
+                    out << ch;
+                }
+                break;
+        }
+    }
+}
