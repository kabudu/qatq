+static llama_kv_cache * llama_qatq_get_kv_cache(struct llama_context * ctx) {
+    if (ctx == nullptr) {
+        return nullptr;
+    }
+    llama_memory_t memory = ctx->get_memory();
+    if (auto * hybrid = dynamic_cast<llama_memory_hybrid *>(memory)) {
+        return hybrid->get_mem_attn();
+    }
+    if (auto * hybrid_iswa = dynamic_cast<llama_memory_hybrid_iswa *>(memory)) {
+        auto * iswa = hybrid_iswa->get_mem_attn();
+        return iswa == nullptr ? nullptr : iswa->get_base();
+    }
+    if (auto * kv = dynamic_cast<llama_kv_cache *>(memory)) {
+        return kv;
+    }
+    return nullptr;
+}
+
+static const llama_kv_cache * llama_qatq_get_kv_cache(const struct llama_context * ctx) {
+    return llama_qatq_get_kv_cache(const_cast<struct llama_context *>(ctx));
+}
