+bool qatq_attention_page_tensor_self_test(
+        const ggml_tensor * stream_tensor,
+        int32_t il,
+        const char * kind,
+        uint32_t stream,
+        uint64_t page_start,
+        uint64_t page_end,
+        uint32_t n_embd,
+        bool v_trans,
+        size_t cells_size) {
+    const char * path = getenv("LLAMA_QATQ_ATTENTION_PAGE_TENSOR_SELF_TEST");
+    if (path == nullptr || path[0] == '\0' || stream_tensor == nullptr || kind == nullptr || page_start >= page_end) {
+        return true;
+    }
+
+    const uint64_t parsed_limit = qatq_parse_u64_env("LLAMA_QATQ_ATTENTION_PAGE_TENSOR_SELF_TEST_LIMIT", 16);
+    if (parsed_limit == 0) {
+        return true;
+    }
+    const uint32_t test_index = g_qatq_attention_page_tensor_self_tests.fetch_add(1);
+    if (test_index >= parsed_limit) {
+        return true;
+    }
+    if (stream_tensor->buffer == nullptr) {
+        LLAMA_LOG_ERROR("%s: missing stream tensor backend buffer\n", __func__);
+        return false;
+    }
+
+    ggml_backend_buffer_type_t buft = ggml_backend_buffer_get_type(stream_tensor->buffer);
+    if (buft == nullptr || ggml_backend_buft_is_host(buft)) {
+        return true;
+    }
+
+    const size_t el_size = ggml_type_size(stream_tensor->type);
+    const size_t row_size = ggml_row_size(stream_tensor->type, n_embd);
+    const uint64_t page_tokens = page_end - page_start;
+    std::vector<uint8_t> source_page;
+    source_page.reserve(static_cast<size_t>(page_tokens) * row_size);
+
+    if (strcmp(kind, "value") == 0 && v_trans) {
+        for (uint32_t j = 0; j < n_embd; ++j) {
+            for (uint64_t cell = page_start; cell < page_end; ++cell) {
+                const size_t offset = (static_cast<size_t>(cell) + static_cast<size_t>(j) * cells_size) * el_size;
+                auto item = qatq_read_tensor_slice(stream_tensor, offset, el_size, nullptr);
+                source_page.insert(source_page.end(), item.begin(), item.end());
+            }
+        }
+    } else {
+        for (uint64_t cell = page_start; cell < page_end; ++cell) {
+            auto row = qatq_read_tensor_slice(stream_tensor, static_cast<size_t>(cell) * row_size, row_size, nullptr);
+            source_page.insert(source_page.end(), row.begin(), row.end());
+        }
+    }
+
+    const size_t page_bytes = source_page.size();
+    if (page_bytes == 0) {
+        LLAMA_LOG_ERROR("%s: empty QATQ attention page tensor self-test page\n", __func__);
+        return false;
+    }
+
+    const size_t ctx_size = ggml_tensor_overhead() + ggml_graph_overhead();
+    std::vector<uint8_t> ctx_mem(ctx_size);
+    struct ggml_init_params params = {
+        /*.mem_size   =*/ ctx_mem.size(),
+        /*.mem_buffer =*/ ctx_mem.data(),
+        /*.no_alloc   =*/ true,
+    };
+    ggml_context_ptr page_ctx { ggml_init(params) };
+    if (!page_ctx) {
+        LLAMA_LOG_ERROR("%s: failed to create QATQ attention page tensor context\n", __func__);
+        return false;
+    }
+
+    ggml_tensor * page_tensor = (strcmp(kind, "value") == 0 && v_trans)
+        ? ggml_new_tensor_2d(page_ctx.get(), stream_tensor->type, page_tokens, n_embd)
+        : ggml_new_tensor_2d(page_ctx.get(), stream_tensor->type, n_embd, page_tokens);
+    if (page_tensor == nullptr) {
+        LLAMA_LOG_ERROR("%s: failed to create QATQ attention page tensor\n", __func__);
+        return false;
+    }
+    ggml_format_name(page_tensor, "qatq_attention_page_l%d_s%d", il, stream);
+
+    ggml_backend_buffer_t page_buf = ggml_backend_alloc_ctx_tensors_from_buft(page_ctx.get(), buft);
+    if (page_buf == nullptr) {
+        LLAMA_LOG_ERROR("%s: failed to allocate QATQ attention page tensor buffer\n", __func__);
+        return false;
+    }
+
+    const size_t allocated_bytes = ggml_backend_buffer_get_size(page_buf);
+    if (allocated_bytes < page_bytes) {
+        LLAMA_LOG_ERROR(
+                "%s: QATQ attention page tensor buffer too small: allocated %zu bytes for %zu byte page\n",
+                __func__,
+                allocated_bytes,
+                page_bytes);
+        ggml_backend_buffer_free(page_buf);
+        return false;
+    }
+
+    ggml_backend_tensor_set(page_tensor, source_page.data(), 0, source_page.size());
+    std::vector<uint8_t> roundtrip(source_page.size());
+    ggml_backend_tensor_get(page_tensor, roundtrip.data(), 0, roundtrip.size());
+    if (roundtrip != source_page) {
+        LLAMA_LOG_ERROR("%s: QATQ attention page tensor round-trip mismatch\n", __func__);
+        ggml_backend_buffer_free(page_buf);
+        return false;
+    }
+    ggml_backend_buffer_free(page_buf);
+
+    std::error_code ec;
+    std::filesystem::path out_file(path);
+    if (out_file.has_parent_path()) {
+        std::filesystem::create_directories(out_file.parent_path(), ec);
+        if (ec) {
+            LLAMA_LOG_ERROR("%s: failed to create QATQ attention page tensor trace parent directory %s: %s\n", __func__, out_file.parent_path().string().c_str(), ec.message().c_str());
+            return false;
+        }
+    }
+    std::ofstream out(out_file, std::ios::binary | std::ios::app);
+    if (!out) {
+        LLAMA_LOG_ERROR("%s: failed to open QATQ attention page tensor trace %s\n", __func__, path);
+        return false;
+    }
+    out << "{\"event\":\"attention-page-tensor-roundtrip\""
+        << ",\"backend\":\"";
+    qatq_write_json_escaped(out, ggml_backend_buft_name(buft));
+    out << "\",\"layer_id\":" << il
+        << ",\"stream\":" << stream
+        << ",\"kind\":\"" << kind
+        << "\",\"token_start\":" << page_start
+        << ",\"token_end\":" << page_end
+        << ",\"requested_bytes\":" << page_bytes
+        << ",\"allocated_bytes\":" << allocated_bytes
+        << ",\"test_index\":" << test_index
+        << "}\n";
+
+    LLAMA_LOG_INFO(
+            "%s: QATQ attention page tensor self-test round-tripped %s %s page tensor for layer %d stream %u tokens %llu..%llu (%zu requested bytes, %zu allocated bytes)\n",
+            __func__,
+            ggml_backend_buft_name(buft),
+            kind,
+            il,
+            stream,
+            (unsigned long long) page_start,
+            (unsigned long long) page_end,
+            page_bytes,
+            allocated_bytes);
+    return true;
+}
