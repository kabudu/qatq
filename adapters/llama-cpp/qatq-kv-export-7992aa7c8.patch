+        if (ec) {
+            LLAMA_LOG_ERROR("%s: failed to create attention trace parent directory %s: %s\n", __func__, trace_file.parent_path().string().c_str(), ec.message().c_str());
+            return;
+        }
+    }
+
+    std::ofstream trace(trace_file, std::ios::binary | std::ios::app);
+    if (!trace) {
+        LLAMA_LOG_ERROR("%s: failed to open QATQ attention trace %s\n", __func__, path);
+        return;
+    }
+
+    const char * model_id = getenv("LLAMA_QATQ_MODEL_ID");
+    const uint32_t stream_id = sinfo.strm.empty() ? 0 : sinfo.strm[0];
+
+    trace << "{";
+    trace << "\"format\":\"qatq-live-vram-attention-trace-v1\",";
+    trace << "\"event\":\"attention-use\",";
+    trace << "\"runtime_id\":\"llama.cpp\",";
+    trace << "\"model_id\":\"";
+    qatq_write_json_escaped(trace, model_id != nullptr && model_id[0] != '\0' ? model_id : "llama.cpp");
+    trace << "\",";
+    trace << "\"seq_id\":\"" << stream_id << "\",";
+    trace << "\"layer_id\":" << il << ",";
+    trace << "\"kind\":\"" << kind << "\",";
+    trace << "\"token_start\":0,";
+    trace << "\"token_end\":" << n_kv << ",";
+    trace << "\"streams\":[";
+    for (size_t i = 0; i < sinfo.strm.size(); ++i) {
+        if (i > 0) {
+            trace << ",";
+        }
+        trace << sinfo.strm[i];
+    }
+    trace << "]";
+    trace << "}\n";
+}
