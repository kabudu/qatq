+void qatq_trace_attention_materialized_source(
+        int32_t il,
+        const char * kind,
+        uint32_t n_kv,
+        const llama_kv_cache::slot_info & sinfo,
+        const ggml_tensor * source,
+        const ggml_tensor * materialized) {
+    const char * path = getenv("LLAMA_QATQ_ATTENTION_MATERIALIZED_SOURCE_TRACE");
+    if (path == nullptr || path[0] == '\0' || kind == nullptr || source == nullptr || materialized == nullptr) {
+        return;
+    }
+
+    std::error_code ec;
+    std::filesystem::path trace_file(path);
+    if (trace_file.has_parent_path()) {
+        std::filesystem::create_directories(trace_file.parent_path(), ec);
+        if (ec) {
+            LLAMA_LOG_ERROR("%s: failed to create materialized source trace parent directory %s: %s\n", __func__, trace_file.parent_path().string().c_str(), ec.message().c_str());
+            return;
+        }
+    }
+
+    std::ofstream trace(trace_file, std::ios::binary | std::ios::app);
+    if (!trace) {
+        LLAMA_LOG_ERROR("%s: failed to open QATQ materialized source trace %s\n", __func__, path);
+        return;
+    }
+
+    const char * model_id = getenv("LLAMA_QATQ_MODEL_ID");
+    const uint32_t stream_id = sinfo.strm.empty() ? 0 : sinfo.strm[0];
+    const uint32_t event_index = g_qatq_attention_materialized_source_events.fetch_add(1);
+    const size_t source_bytes = ggml_nbytes(source);
+    const size_t materialized_bytes = ggml_nbytes(materialized);
+
+    trace << "{";
+    trace << "\"format\":\"qatq-live-vram-attention-materialized-source-v1\",";
+    trace << "\"event\":\"attention-materialized-source\",";
+    trace << "\"runtime_id\":\"llama.cpp\",";
+    trace << "\"model_id\":\"";
+    qatq_write_json_escaped(trace, model_id != nullptr && model_id[0] != '\0' ? model_id : "llama.cpp");
+    trace << "\",";
+    trace << "\"seq_id\":\"" << stream_id << "\",";
+    trace << "\"layer_id\":" << il << ",";
+    trace << "\"kind\":\"" << kind << "\",";
+    trace << "\"n_kv\":" << n_kv << ",";
+    trace << "\"source_bytes\":" << source_bytes << ",";
+    trace << "\"materialized_bytes\":" << materialized_bytes << ",";
+    trace << "\"event_index\":" << event_index << ",";
+    trace << "\"source_shape\":[";
+    for (int i = 0; i < GGML_MAX_DIMS; ++i) {
+        if (i > 0) {
+            trace << ",";
+        }
+        trace << source->ne[i];
+    }
+    trace << "],\"materialized_shape\":[";
+    for (int i = 0; i < GGML_MAX_DIMS; ++i) {
+        if (i > 0) {
+            trace << ",";
+        }
+        trace << materialized->ne[i];
+    }
+    trace << "]}\n";
+}
