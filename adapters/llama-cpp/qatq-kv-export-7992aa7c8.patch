+static bool parse_qatq_cache_type(const char * value, ggml_type * out) {
+    if (strcmp(value, "f16") == 0) {
+        *out = GGML_TYPE_F16;
+        return true;
+    }
+    if (strcmp(value, "bf16") == 0) {
+        *out = GGML_TYPE_BF16;
+        return true;
+    }
+    if (strcmp(value, "f32") == 0) {
+        *out = GGML_TYPE_F32;
+        return true;
+    }
+    return false;
+}
