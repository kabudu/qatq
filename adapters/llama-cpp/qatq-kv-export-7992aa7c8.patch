From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: QATQ Adapter <qatq@example.invalid>
Date: Mon, 22 Jun 2026 00:00:00 +0100
Subject: [PATCH] llama.cpp: add QATQ raw KV tensor export hook

Target llama.cpp commit: 7992aa7c8, reported by Homebrew llama-cli build 8640.

This patch adds a narrow public export hook for QATQ experiments. It does not
change model execution. It copies active KV-cache tensor bytes into raw
little-endian `.f16le`, `.bf16le`, or `.f32le` files plus a small manifest.

Runtime guidance:

  llama.cpp should be run CPU-readable for the first evidence pass, for example
  with `--device none --gpu-layers 0 --no-kv-offload --cache-type-k f16
  --cache-type-v f16`. GPU-resident KV export can be added later once the
  backend copy path is validated for the target backend.

diff --git a/include/llama.h b/include/llama.h
index 0000000000..0000000000 100644
--- a/include/llama.h
+++ b/include/llama.h
@@
     LLAMA_API int32_t llama_state_seq_load_file(
             struct llama_context * ctx,
                      const char * path_session,
                      llama_seq_id   seq_id,
                          int32_t * n_token_count_out);
+
+    // Experimental QATQ adapter hook.
+    //
+    // Exports active internal KV tensors for `seq_id` as raw typed little-endian
+    // files in `dir`. Supported KV cache dtypes are f16, bf16, and f32.
+    // Returns false when the current context does not use llama_kv_cache, the
+    // dtype is unsupported, or a filesystem/backend copy error occurs.
+    LLAMA_API bool llama_qatq_export_kv_cache(
+            struct llama_context * ctx,
+                     const char * dir,
+                   llama_seq_id   seq_id);
 
 #ifdef __cplusplus
 }
diff --git a/src/llama-context.h b/src/llama-context.h
index 0000000000..0000000000 100644
--- a/src/llama-context.h
+++ b/src/llama-context.h
@@
     uint32_t get_ctx_train() const;
 
     int32_t get_n_threads()       const;
     int32_t get_n_threads_batch() const;
+
+    bool qatq_export_kv_cache(const char * dir, llama_seq_id seq_id) const;
 
     bool has_encoder() const;
     bool has_decoder() const;
diff --git a/src/llama-context.cpp b/src/llama-context.cpp
index 0000000000..0000000000 100644
--- a/src/llama-context.cpp
+++ b/src/llama-context.cpp
@@
 #include "llama-context.h"
+#include "llama-kv-cache.h"
@@
+bool llama_context::qatq_export_kv_cache(const char * dir, llama_seq_id seq_id) const {
+    if (dir == nullptr || dir[0] == '\0') {
+        return false;
+    }
+
+    auto * kv = dynamic_cast<llama_kv_cache *>(memory.get());
+    if (kv == nullptr) {
+        return false;
+    }
+
+    return kv->export_qatq_tensors(dir, seq_id);
+}
+
diff --git a/src/llama.cpp b/src/llama.cpp
index 0000000000..0000000000 100644
--- a/src/llama.cpp
+++ b/src/llama.cpp
@@
+bool llama_qatq_export_kv_cache(struct llama_context * ctx, const char * dir, llama_seq_id seq_id) {
+    if (ctx == nullptr) {
+        return false;
+    }
+    return ctx->qatq_export_kv_cache(dir, seq_id);
+}
+
diff --git a/src/llama-kv-cache.h b/src/llama-kv-cache.h
index 0000000000..0000000000 100644
--- a/src/llama-kv-cache.h
+++ b/src/llama-kv-cache.h
@@
 #include <cstdint>
 #include <memory>
+#include <string>
 #include <vector>
@@
     ggml_type type_v;
 
     bool v_trans = true;
 
+    bool export_qatq_tensors(const std::string & dir, llama_seq_id seq_id) const;
+
 private:
     struct kv_layer {
         uint32_t il;
diff --git a/src/llama-kv-cache.cpp b/src/llama-kv-cache.cpp
index 0000000000..0000000000 100644
--- a/src/llama-kv-cache.cpp
+++ b/src/llama-kv-cache.cpp
@@
 #include "llama-kv-cache.h"
 
+#include <filesystem>
+#include <fstream>
+#include <string>
+#include <vector>
+
+namespace {
+
+const char * qatq_dtype_suffix(ggml_type type) {
+    switch (type) {
+        case GGML_TYPE_F16:  return "f16le";
+        case GGML_TYPE_BF16: return "bf16le";
+        case GGML_TYPE_F32:  return "f32le";
+        default:             return nullptr;
+    }
+}
+
+bool qatq_write_tensor_slice(std::ofstream & out, const ggml_tensor * tensor, size_t offset, size_t size) {
+    std::vector<uint8_t> buf(size);
+    ggml_backend_tensor_get(tensor, buf.data(), offset, size);
+    out.write(reinterpret_cast<const char *>(buf.data()), static_cast<std::streamsize>(buf.size()));
+    return out.good();
+}
+
+} // namespace
+
+bool llama_kv_cache::export_qatq_tensors(const std::string & dir, llama_seq_id seq_id) const {
+    const char * k_suffix = qatq_dtype_suffix(type_k);
+    const char * v_suffix = qatq_dtype_suffix(type_v);
+    if (k_suffix == nullptr || v_suffix == nullptr) {
+        LLAMA_LOG_ERROR("%s: QATQ export supports only f16, bf16, and f32 KV cache types\n", __func__);
+        return false;
+    }
+
+    const std::filesystem::path out_dir(dir);
+    std::error_code ec;
+    std::filesystem::create_directories(out_dir, ec);
+    if (ec) {
+        LLAMA_LOG_ERROR("%s: failed to create %s: %s\n", __func__, dir.c_str(), ec.message().c_str());
+        return false;
+    }
+
+    std::ofstream manifest(out_dir / "manifest.json", std::ios::binary);
+    if (!manifest) {
+        LLAMA_LOG_ERROR("%s: failed to create manifest in %s\n", __func__, dir.c_str());
+        return false;
+    }
+
+    manifest << "{\n";
+    manifest << "  \"format\": \"qatq-llama-cpp-kv-v1\",\n";
+    manifest << "  \"seq_id\": " << seq_id << ",\n";
+    manifest << "  \"tensors\": [\n";
+
+    bool first_manifest = true;
+    for (size_t s = 0; s < v_cells.size(); ++s) {
+        const auto & cells = v_cells[s];
+        std::vector<uint32_t> active;
+        active.reserve(cells.size());
+        for (uint32_t i = 0; i < cells.size(); ++i) {
+            if (cells.seq_has(i, seq_id)) {
+                active.push_back(i);
+            }
+        }
+        if (active.empty()) {
+            continue;
+        }
+
+        for (const auto & layer : layers) {
+            if (layer.k != nullptr) {
+                const auto * k = layer.k_stream[s];
+                const size_t k_row_size = ggml_row_size(k->type, n_embd_k_gqa);
+                const std::string filename = "cache_k_l" + std::to_string(layer.il) + "_s" + std::to_string(s) + "." + k_suffix;
+                std::ofstream out(out_dir / filename, std::ios::binary);
+                if (!out) {
+                    return false;
+                }
+                for (uint32_t cell : active) {
+                    if (!qatq_write_tensor_slice(out, k, cell * k_row_size, k_row_size)) {
+                        return false;
+                    }
+                }
+                if (!first_manifest) manifest << ",\n";
+                first_manifest = false;
+                manifest << "    {\"name\":\"cache_k_l" << layer.il << "\",\"stream\":" << s
+                         << ",\"file\":\"" << filename << "\",\"dtype\":\"" << k_suffix
+                         << "\",\"active_cells\":" << active.size()
+                         << ",\"row_bytes\":" << k_row_size << "}";
+            }
+
+            if (layer.v != nullptr) {
+                const auto * v = layer.v_stream[s];
+                const size_t v_el_size = ggml_type_size(v->type);
+                const size_t v_row_size = ggml_row_size(v->type, n_embd_v_gqa);
+                const std::string filename = "cache_v_l" + std::to_string(layer.il) + "_s" + std::to_string(s) + "." + v_suffix;
+                std::ofstream out(out_dir / filename, std::ios::binary);
+                if (!out) {
+                    return false;
+                }
+
+                if (v_trans) {
+                    for (size_t j = 0; j < n_embd_v_gqa; ++j) {
+                        for (uint32_t cell : active) {
+                            const size_t offset = (cell + j * kv_size) * v_el_size;
+                            if (!qatq_write_tensor_slice(out, v, offset, v_el_size)) {
+                                return false;
+                            }
+                        }
+                    }
+                } else {
+                    for (uint32_t cell : active) {
+                        if (!qatq_write_tensor_slice(out, v, cell * v_row_size, v_row_size)) {
+                            return false;
+                        }
+                    }
+                }
+
+                if (!first_manifest) manifest << ",\n";
+                first_manifest = false;
+                manifest << "    {\"name\":\"cache_v_l" << layer.il << "\",\"stream\":" << s
+                         << ",\"file\":\"" << filename << "\",\"dtype\":\"" << v_suffix
+                         << "\",\"active_cells\":" << active.size()
+                         << ",\"row_bytes\":" << v_row_size
+                         << ",\"transposed\":" << (v_trans ? "true" : "false") << "}";
+            }
+        }
+    }
+
+    manifest << "\n  ]\n";
+    manifest << "}\n";
+    return manifest.good();
+}
