+ggml_tensor * qatq_page_view_for_attention_source(
+        ggml_context * ctx,
+        ggml_tensor * source,
+        uint64_t page_start,
+        uint64_t page_end,
+        int concat_dim) {
+    const int64_t page_tokens = static_cast<int64_t>(page_end - page_start);
+    if (concat_dim == 0) {
+        return ggml_view_4d(
+                ctx,
+                source,
+                page_tokens,
+                source->ne[1],
+                source->ne[2],
+                source->ne[3],
+                source->nb[1],
+                source->nb[2],
+                source->nb[3],
+                static_cast<size_t>(page_start) * source->nb[0]);
+    }
+
+    return ggml_view_4d(
+            ctx,
+            source,
+            source->ne[0],
+            source->ne[1],
+            page_tokens,
+            source->ne[3],
+            source->nb[1],
+            source->nb[2],
+            source->nb[3],
+            static_cast<size_t>(page_start) * source->nb[2]);
+}
+
+ggml_tensor * qatq_stream_page_view_for_attention_source(
+        ggml_context * ctx,
+        ggml_tensor * page,
+        uint32_t stream_index) {
+    if (page == nullptr) {
+        return nullptr;
+    }
+    if (stream_index >= static_cast<uint32_t>(page->ne[3])) {
+        throw std::runtime_error("QATQ stream page view requested stream outside page extent");
+    }
+    return ggml_view_4d(
+            ctx,
+            page,
+            page->ne[0],
+            page->ne[1],
+            page->ne[2],
+            1,
+            page->nb[1],
+            page->nb[2],
+            page->nb[3],
+            static_cast<size_t>(stream_index) * page->nb[3]);
+}
+
+ggml_tensor * qatq_maybe_page_compose_attention_source(
+        ggml_context * ctx,
+        ggml_tensor * source,
+        int32_t il,
+        const char * kind,
+        uint32_t n_kv,
+        int concat_dim,
+        const llama_kv_cache::slot_info & sinfo) {
+    if (!qatq_attention_page_composed_source_enabled()) {
+        return nullptr;
+    }
+
+    uint64_t page_tokens = qatq_parse_u64_env("LLAMA_QATQ_PAGE_TOKENS", 0);
+    if (page_tokens == 0 || page_tokens > n_kv) {
+        page_tokens = n_kv;
+    }
+
+    ggml_tensor * composed = nullptr;
+    uint64_t page_count = 0;
+    for (uint64_t page_start = 0; page_start < n_kv; page_start += page_tokens) {
+        const uint64_t page_end = std::min<uint64_t>(page_start + page_tokens, n_kv);
+        ggml_tensor * page = qatq_page_view_for_attention_source(ctx, source, page_start, page_end, concat_dim);
+        ggml_tensor * materialized_page = ggml_cont(ctx, page);
+        ggml_format_name(materialized_page, "qatq_page_source_%s_l%d_%llu_%llu", kind, il, (unsigned long long) page_start, (unsigned long long) page_end);
+        composed = composed == nullptr ? materialized_page : ggml_concat(ctx, composed, materialized_page, concat_dim);
+        ++page_count;
+    }
+
+    if (composed == nullptr) {
+        return source;
+    }
+    ggml_set_name(composed, strcmp(kind, "key") == 0 ? "qatq_page_composed_k" : "qatq_page_composed_v");
+    qatq_trace_attention_page_composed_source(il, kind, n_kv, page_tokens, page_count, sinfo, source, composed);
+    return composed;
+}
+
+ggml_tensor * qatq_maybe_materialize_attention_source(
+        ggml_context * ctx,
+        ggml_tensor * source,
+        int32_t il,
+        const char * kind,
+        uint32_t n_kv,
+        int concat_dim,
+        const llama_kv_cache::slot_info & sinfo) {
+    ggml_tensor * page_composed = qatq_maybe_page_compose_attention_source(ctx, source, il, kind, n_kv, concat_dim, sinfo);
+    if (page_composed != nullptr) {
+        return page_composed;
+    }
+    if (!qatq_attention_materialized_source_enabled()) {
+        return source;
+    }
+
+    ggml_tensor * materialized = ggml_cont(ctx, source);
+    ggml_set_name(materialized, strcmp(kind, "key") == 0 ? "qatq_materialized_k" : "qatq_materialized_v");
+    qatq_trace_attention_materialized_source(il, kind, n_kv, sinfo, source, materialized);
+    return materialized;
+}
