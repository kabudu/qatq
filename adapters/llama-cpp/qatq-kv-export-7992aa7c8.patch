+std::string qatq_live_page_key(
+        llama_seq_id seq_id,
+        uint32_t layer_id,
+        uint32_t stream_id,
+        uint32_t token_start,
+        uint32_t token_end,
+        const char * kind) {
+    std::string key;
+    key.reserve(96);
+    key += std::to_string(seq_id);
+    key += ':';
+    key += std::to_string(layer_id);
+    key += ':';
+    key += std::to_string(stream_id);
+    key += ':';
+    key += kind != nullptr ? kind : "";
+    key += ':';
+    key += std::to_string(token_start);
+    key += ':';
+    key += std::to_string(token_end);
+    return key;
+}
