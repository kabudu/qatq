+            kq = ggml_scale(ctx0, kq, hparams.f_attn_logit_softcapping);
+        }
+
+        cb(kq, "ggml_segmented_kqv_kq_page", il);
+        kq_all = kq_all == nullptr ? kq : ggml_concat(ctx0, kq_all, kq, 0);
+    }
+
+    ggml_format_name(kq_all, "ggml_segmented_kqv_logits");
+    cb(kq_all, "ggml_segmented_kqv_logits", il);
+
+    kq_all = ggml_soft_max_ext(ctx0, kq_all, kq_mask, kq_scale, hparams.f_max_alibi_bias);
+    ggml_format_name(kq_all, "ggml_segmented_kqv_global_softmax");
+    cb(kq_all, "ggml_segmented_kqv_global_softmax", il);
+
+    ggml_tensor * kqv = nullptr;
+    int64_t token_offset = 0;
+    for (size_t i = 0; i < v_segments.size(); ++i) {
+        const int64_t page_tokens = static_cast<int64_t>(v_segments[i].token_end - v_segments[i].token_start);
+        ggml_tensor * kq_page = ggml_view_4d(
+                ctx0,
+                kq_all,
+                page_tokens,
+                kq_all->ne[1],
+                kq_all->ne[2],
+                kq_all->ne[3],
+                kq_all->nb[1],
+                kq_all->nb[2],
+                kq_all->nb[3],
+                static_cast<size_t>(token_offset*kq_all->nb[0]));
+        ggml_format_name(kq_page, "ggml_segmented_kqv_prob_page_%zu", i);
+
+        ggml_tensor * v_src = v_segments[i].sync_tensor != nullptr ? v_segments[i].sync_tensor : v_segments[i].tensor;
+        ggml_tensor * v = ggml_permute(ctx0, v_src, 0, 2, 1, 3);
+        if (!v_trans) {
+            v = ggml_cont(ctx0, ggml_transpose(ctx0, v));
+        }
+
+        ggml_tensor * kqv_page = ggml_mul_mat(ctx0, v, kq_page);
+        cb(kqv_page, "ggml_segmented_kqv_page_out", il);
+        kqv = kqv == nullptr ? kqv_page : ggml_add(ctx0, kqv, kqv_page);
+        token_offset += page_tokens;
+    }
+
+    ggml_format_name(kqv, "ggml_segmented_kqv_logits_bridge");
+    cb(kqv, "ggml_segmented_kqv_logits_bridge", il);
+
+    ggml_tensor * cur = ggml_permute(ctx0, kqv, 0, 2, 1, 3);
+    cur = ggml_cont_2d(ctx0, cur, cur->ne[0]*cur->ne[1], cur->ne[2]*cur->ne[3]);
+
+    if (!cparams.offload_kqv) {
+        ggml_backend_sched_set_tensor_backend(sched, cur, backend_cpu);
+    }
+
+    ggml_build_forward_expand(gf, cur);
+    return cur;
+}
