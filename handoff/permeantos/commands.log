# PermeantOS / QATQ decision-path commands - 2026-06-21

# PermeantOS build/test
cargo fmt --check
cargo check
cargo test

# Local daemon for live migration tests
cargo run -p permeant-cli -- daemon --addr 127.0.0.1:19099

# Live compressed-path migration using deterministic mock KV
cargo run -p permeant-cli -- sim-migrate --target-addr 127.0.0.1:19099 --seq-len 512 --transfer-codec qatq

# Live pass-through migration using GPT-2 f32le captures via command-backed extractor
PERMEANT_EXTRACTOR_MODE=json_command \
PERMEANT_EXTRACTOR_CMD='node /private/tmp/permeant_fixture_extractor.js' \
PERMEANT_KEY_F32LE=/Users/kabudu/projex/qatq/captures/permeantos-20260621-expanded/gpt2-seq64-layer0-key.f32le \
PERMEANT_VALUE_F32LE=/Users/kabudu/projex/qatq/captures/permeantos-20260621-expanded/gpt2-seq64-layer0-value.f32le \
PERMEANT_MODEL_ARCHITECTURE=gpt2 \
PERMEANT_MODEL_IDENTITY=gpt2 \
PERMEANT_MODEL_LAYER_COUNT=1 \
PERMEANT_MODEL_Q_HEADS=12 \
PERMEANT_MODEL_KV_HEADS=12 \
PERMEANT_MODEL_HEAD_DIM=64 \
PERMEANT_MODEL_HIDDEN_SIZE=768 \
PERMEANT_MODEL_BLOCK_SIZE=64 \
cargo run -p permeant-cli -- sim-migrate --target-addr 127.0.0.1:19099 --seq-len 64 --transfer-codec qatq

# QATQ validation
cargo fmt --check
cargo check
cargo test
cargo run --bin qatq -- fixture verify --manifest fixtures/permeantos.manifest --output docs/FIXTURE_AUDIT.md
cargo run --release --bin qatq-bench -- --phase2-only --no-synthetic --output docs/BENCHMARKS.md --paper-output docs/PAPER_TABLES.md --manifest fixtures/permeantos.manifest
cargo run --release --bin qatq-bench -- --phase2-only --no-synthetic --manifest fixtures/permeantos.manifest --gate-output docs/BENCHMARK_GATE_THROUGHPUT.md --gate-require-external --gate-policy production-kv --max-phase2-ratio 0.95 --max-phase2-encode-us 5000 --max-phase2-decode-ns-per-value 3.00 --max-phase2-container-ratio 0.96 --max-phase2-container-decode-ns-per-value 3.00
cargo run --release --bin qatq-bench -- --phase2-only --no-synthetic --manifest fixtures/permeantos.manifest --gate-output docs/BENCHMARK_GATE.md --gate-require-external --gate-policy latency-budget --max-phase2-ratio 0.95 --max-phase2-encode-us 5000 --max-phase2-decode-us 1000 --max-phase2-container-ratio 0.96 --max-phase2-container-decode-us 1200
cargo test --test bench
