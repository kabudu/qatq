+uint64_t qatq_parse_u64_env(const char * name, uint64_t fallback) {
+    const char * value = getenv(name);
+    if (value == nullptr || value[0] == '\0') {
+        return fallback;
+    }
+    char * end = nullptr;
+    errno = 0;
+    const unsigned long long parsed = strtoull(value, &end, 10);
+    if (errno != 0 || end == value || *end != '\0') {
+        LLAMA_LOG_ERROR("%s: invalid %s value %s\n", __func__, name, value);
+        return fallback;
+    }
+    return static_cast<uint64_t>(parsed);
+}
