+bool qatq_trace_uses_page_end_next_required() {
+    const char * value = getenv("LLAMA_QATQ_TRACE_NEXT_REQUIRED");
+    return value != nullptr && strcmp(value, "page-end") == 0;
+}
+
+bool qatq_trace_uses_cold_after_hot_next_required() {
+    const char * value = getenv("LLAMA_QATQ_TRACE_NEXT_REQUIRED");
+    return value != nullptr && strcmp(value, "cold-after-hot") == 0;
+}
+
+bool qatq_trace_queue_allows_offload(uint64_t queued_pages) {
+    const uint64_t max_queued_pages = qatq_parse_u64_env(
+            "LLAMA_QATQ_TRACE_MAX_QUEUED_PAGES",
+            std::numeric_limits<uint64_t>::max());
+    return queued_pages < max_queued_pages;
+}
+
+bool qatq_trace_should_offload_page(const qatq_trace_page & page, uint64_t current_token, uint64_t hot_window_tokens, uint64_t prefetch_window_tokens) {
+    const uint64_t min_offload_page_tokens = qatq_parse_u64_env("LLAMA_QATQ_TRACE_MIN_OFFLOAD_PAGE_TOKENS", 16);
+    const uint64_t actual_page_tokens = static_cast<uint64_t>(page.token_end) - static_cast<uint64_t>(page.token_start);
+    if (actual_page_tokens < min_offload_page_tokens) {
+        return false;
+    }
+
+    const char * hot_window_env = getenv("LLAMA_QATQ_TRACE_HOT_WINDOW_TOKENS");
+    if (hot_window_env == nullptr || hot_window_env[0] == '\0') {
+        return true;
+    }
+
+    if (qatq_trace_uses_cold_after_hot_next_required()) {
+        const uint64_t hot_start = current_token > hot_window_tokens ? current_token - hot_window_tokens : 0;
+        return static_cast<uint64_t>(page.token_end) <= hot_start;
+    }
+
+    const uint64_t hot_until = current_token > std::numeric_limits<uint64_t>::max() - hot_window_tokens
+        ? std::numeric_limits<uint64_t>::max()
+        : current_token + hot_window_tokens;
+    const uint64_t prefetch_until = hot_until > std::numeric_limits<uint64_t>::max() - prefetch_window_tokens
+        ? std::numeric_limits<uint64_t>::max()
+        : hot_until + prefetch_window_tokens;
+    const uint64_t next_required = qatq_trace_uses_page_end_next_required()
+        ? static_cast<uint64_t>(page.token_end)
+        : (prefetch_until == std::numeric_limits<uint64_t>::max() ? prefetch_until : prefetch_until + 1);
+    return next_required > prefetch_until;
+}
+
+void qatq_write_trace_event(
+        std::ofstream & trace,
+        int64_t token,
+        const char * event,
+        const char * model_id,
+        llama_seq_id seq_id,
+        const qatq_trace_page & page,
+        bool include_checksum,
+        bool trailing_comma) {
+    trace << "    {\n";
+    trace << "      \"token\": " << token << ",\n";
+    trace << "      \"event\": \"" << event << "\",\n";
+    trace << "      \"runtime_id\": \"llama.cpp\",\n";
+    trace << "      \"model_id\": \"";
+    qatq_write_json_escaped(trace, model_id != nullptr && model_id[0] != '\0' ? model_id : "llama.cpp");
+    trace << "\",\n";
+    trace << "      \"seq_id\": \"" << seq_id << "\",\n";
+    trace << "      \"layer_id\": " << page.layer_id << ",\n";
+    trace << "      \"kind\": \"" << page.kind << "\",\n";
+    trace << "      \"token_start\": " << page.token_start << ",\n";
+    trace << "      \"token_end\": " << page.token_end;
+    if (include_checksum) {
+        trace << ",\n";
+        trace << "      \"checksum\": " << page.checksum << "\n";
+    } else {
+        trace << "\n";
+    }
+    trace << "    }";
+    if (trailing_comma) {
+        trace << ",";
+    }
+    trace << "\n";
+}
