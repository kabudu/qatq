+struct ggml_tensor * ggml_qatq_segmented_kqv(
+        struct ggml_context * ctx,
+        struct ggml_tensor  * q,
+        struct ggml_tensor  * k,
+        struct ggml_tensor  * v,
+        struct ggml_tensor  * page_offsets,
+        struct ggml_tensor  * token_pages,
+        struct ggml_tensor  * token_locals,
+        struct ggml_tensor  * mask,
+        float                 scale,
+        int64_t               n_kv) {
+    GGML_ASSERT(q->type == GGML_TYPE_F32);
+    GGML_ASSERT(k->type == GGML_TYPE_F32 || k->type == GGML_TYPE_F16 || k->type == GGML_TYPE_BF16);
+    GGML_ASSERT(v->type == k->type);
+    GGML_ASSERT(page_offsets->type == GGML_TYPE_I32);
+    GGML_ASSERT(token_pages->type == GGML_TYPE_I32);
+    GGML_ASSERT(token_locals->type == GGML_TYPE_I32);
+    GGML_ASSERT(mask->type == GGML_TYPE_F32 || mask->type == GGML_TYPE_F16);
+    GGML_ASSERT(ggml_is_contiguous(q));
+    GGML_ASSERT(ggml_is_contiguous(page_offsets));
+    GGML_ASSERT(ggml_is_contiguous(token_pages));
+    GGML_ASSERT(ggml_is_contiguous(token_locals));
+    GGML_ASSERT(ggml_is_contiguous(mask));
+
+    GGML_ASSERT(q->ne[0] == k->ne[0]);
+    GGML_ASSERT(k->ne[0] == v->ne[0]);
+    GGML_ASSERT(k->ne[1] == v->ne[1]);
+    GGML_ASSERT(k->ne[2] == v->ne[2]);
+    GGML_ASSERT(k->ne[3] == v->ne[3]);
+    GGML_ASSERT(q->ne[3] == 1);
+    GGML_ASSERT(page_offsets->ne[0] >= 2);
+    GGML_ASSERT(n_kv > 0);
+    GGML_ASSERT(n_kv <= INT32_MAX);
+    GGML_ASSERT(n_kv <= k->ne[2]*k->ne[3]);
+    GGML_ASSERT(token_pages->ne[0] == n_kv);
+    GGML_ASSERT(token_locals->ne[0] == n_kv);
+    GGML_ASSERT(q->ne[2] % k->ne[1] == 0);
+    GGML_ASSERT(mask->ne[0] == n_kv);
+    GGML_ASSERT(mask->ne[1] == q->ne[1]);
+    GGML_ASSERT(mask->ne[2] == 1);
+    GGML_ASSERT(mask->ne[3] == 1);
+
+    int64_t ne[4] = { v->ne[0], q->ne[2], q->ne[1], 1 };
+    struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);
+
+    ggml_set_op_params(result, &scale, sizeof(scale));
+    ggml_set_op_params_i32(result, 1, (int32_t) n_kv);
+
+    result->op     = GGML_OP_QATQ_SEGMENTED_KQV;
+    result->src[0] = q;
+    result->src[1] = k;
+    result->src[2] = v;
+    result->src[3] = page_offsets;
+    result->src[4] = token_pages;
+    result->src[5] = token_locals;
+    result->src[6] = mask;
+
+    return result;
+}
