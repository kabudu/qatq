+    return qatq_env_enabled("LLAMA_QATQ_NATIVE_PAGE_STREAMING_ATTENTION");
+}
+
+static const char * qatq_native_page_streaming_attention_backend() {
+    const char * value = getenv("LLAMA_QATQ_NATIVE_PAGE_STREAMING_ATTENTION_BACKEND");
+    return value != nullptr && value[0] != '\0' ? value : "ggml";
+}
+
+static bool qatq_native_page_streaming_attention_backend_op_enabled() {
+    return strcmp(qatq_native_page_streaming_attention_backend(), "backend-op") == 0;
+}
+
+static constexpr const char * QATQ_SEGMENTED_KQV_BACKEND_CONTRACT_V1 = "qatq-segmented-kqv-backend-contract-v1";
+static constexpr size_t QATQ_SEGMENTED_KQV_BACKEND_MAX_SEGMENTS = 4096;
+static constexpr uint32_t QATQ_SEGMENTED_KQV_BACKEND_MAX_PAGE_TOKENS = 4096;
+static constexpr uint32_t QATQ_SEGMENTED_KQV_BACKEND_MAX_TOTAL_TOKENS = 8192;
+static constexpr uint64_t QATQ_SEGMENTED_KQV_BACKEND_DEFAULT_TRANSIENT_POOL_MAX_BYTES = 256ull * 1024ull * 1024ull;
+
+static uint64_t qatq_parse_u64_env(
+        const char * name,
+        uint64_t     default_value) {
+    const char * value = getenv(name);
+    if (value == nullptr || value[0] == '\0') {
+        return default_value;
+    }
+    errno = 0;
+    char * end = nullptr;
+    unsigned long long parsed = std::strtoull(value, &end, 10);
+    if (errno != 0 || end == value || *end != '\0') {
+        throw std::runtime_error(std::string("invalid integer in ") + name);
+    }
+    if (parsed > std::numeric_limits<uint64_t>::max()) {
+        throw std::runtime_error(std::string("integer overflow in ") + name);
+    }
+    return static_cast<uint64_t>(parsed);
+}
+
+static void qatq_require_native_page_segment(
+        bool        condition,
+        const char * message) {
+    if (!condition) {
+        throw std::runtime_error(message);
+    }
+}
+
+static void qatq_validate_native_page_segment_pairing(
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & k_segments,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & v_segments) {
+    qatq_require_native_page_segment(!k_segments.empty(), "QATQ native page-streaming preflight found no K segments");
+    qatq_require_native_page_segment(!v_segments.empty(), "QATQ native page-streaming preflight found no V segments");
+    qatq_require_native_page_segment(
+            k_segments.size() == v_segments.size(),
+            "QATQ native page-streaming preflight found mismatched K/V segment counts");
+
+    std::vector<uint32_t> expected_start_by_stream;
+    for (size_t i = 0; i < k_segments.size(); ++i) {
+        const auto & k = k_segments[i];
+        const auto & v = v_segments[i];
+        qatq_require_native_page_segment(k.tensor != nullptr, "QATQ native page-streaming preflight found null K segment tensor");
+        qatq_require_native_page_segment(v.tensor != nullptr, "QATQ native page-streaming preflight found null V segment tensor");
+        qatq_require_native_page_segment(k.bytes > 0, "QATQ native page-streaming preflight found empty K segment bytes");
+        qatq_require_native_page_segment(v.bytes > 0, "QATQ native page-streaming preflight found empty V segment bytes");
+        qatq_require_native_page_segment(
+                k.stream_index == v.stream_index,
+                "QATQ native page-streaming preflight found mismatched K/V stream indices");
+        if (expected_start_by_stream.size() <= k.stream_index) {
+            expected_start_by_stream.resize(static_cast<size_t>(k.stream_index) + 1, 0);
+        }
+        const uint32_t expected_start = expected_start_by_stream[k.stream_index];
+        qatq_require_native_page_segment(
+                k.token_start == expected_start,
+                "QATQ native page-streaming preflight found non-contiguous K segment start");
+        qatq_require_native_page_segment(
+                v.token_start == expected_start,
+                "QATQ native page-streaming preflight found non-contiguous V segment start");
+        qatq_require_native_page_segment(
+                k.token_end > k.token_start,
+                "QATQ native page-streaming preflight found invalid K segment range");
+        qatq_require_native_page_segment(
+                v.token_end > v.token_start,
+                "QATQ native page-streaming preflight found invalid V segment range");
+        qatq_require_native_page_segment(
+                k.token_start == v.token_start && k.token_end == v.token_end,
+                "QATQ native page-streaming preflight found mismatched K/V segment ranges");
+        expected_start_by_stream[k.stream_index] = k.token_end;
+    }
+}
+
+static void qatq_native_page_streaming_preflight(
+        ggml_context * ctx0,
+        const llama_kv_cache_context * mctx_cur,
+        int il) {
+    if (!qatq_native_page_streaming_preflight_enabled()) {
+        return;
+    }
+
+    auto k_segments = mctx_cur->get_k_page_segments(ctx0, il);
+    auto v_segments = mctx_cur->get_v_page_segments(ctx0, il);
+    qatq_validate_native_page_segment_pairing(k_segments, v_segments);
+    mctx_cur->trace_qatq_attention_page_segments(il, "key", k_segments, false, false, "ggml_segmented_kqv_preflight");
+    mctx_cur->trace_qatq_attention_page_segments(il, "value", v_segments, false, false, "ggml_segmented_kqv_preflight");
+}
+
+static void qatq_validate_segmented_kqv_contract(
+        ggml_tensor * q,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & k_segments,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & v_segments,
+        ggml_tensor * kq_b,
+        ggml_tensor * sinks,
+        ggml_tensor * v_mla) {
+    qatq_validate_native_page_segment_pairing(k_segments, v_segments);
+    qatq_require_native_page_segment(q != nullptr, "QATQ segmented KQV contract found a null query tensor");
+    qatq_require_native_page_segment(kq_b == nullptr, "QATQ segmented KQV contract does not support KQ bias yet");
+    qatq_require_native_page_segment(sinks == nullptr, "QATQ segmented KQV contract does not support attention sinks yet");
+    qatq_require_native_page_segment(v_mla == nullptr, "QATQ segmented KQV contract does not support MLA value projection yet");
+
+    const ggml_tensor * first_k = k_segments.front().tensor;
+    const ggml_tensor * first_v = v_segments.front().tensor;
+    qatq_require_native_page_segment(first_k != nullptr, "QATQ segmented KQV contract found a null first K tensor");
+    qatq_require_native_page_segment(first_v != nullptr, "QATQ segmented KQV contract found a null first V tensor");
+    qatq_require_native_page_segment(q->ne[0] == first_k->ne[0], "QATQ segmented KQV contract found mismatched query/key head dimensions");
+    qatq_require_native_page_segment(first_k->type == first_v->type, "QATQ segmented KQV contract requires matching K/V dtypes");
+
+    for (size_t i = 0; i < k_segments.size(); ++i) {
+        const ggml_tensor * k = k_segments[i].tensor;
+        const ggml_tensor * v = v_segments[i].tensor;
+        qatq_require_native_page_segment(k->type == first_k->type, "QATQ segmented KQV contract found mixed K dtypes");
+        qatq_require_native_page_segment(v->type == first_v->type, "QATQ segmented KQV contract found mixed V dtypes");
+        qatq_require_native_page_segment(k->ne[0] == first_k->ne[0], "QATQ segmented KQV contract found mixed K head dimensions");
+        qatq_require_native_page_segment(v->ne[0] == first_v->ne[0], "QATQ segmented KQV contract found mixed V head dimensions");
+        qatq_require_native_page_segment(k->ne[1] == first_k->ne[1], "QATQ segmented KQV contract found mixed K head counts");
+        qatq_require_native_page_segment(v->ne[1] == first_v->ne[1], "QATQ segmented KQV contract found mixed V head counts");
+        qatq_require_native_page_segment(k->ne[2] == static_cast<int64_t>(k_segments[i].token_end - k_segments[i].token_start), "QATQ segmented KQV contract found K token extent mismatch");
+        qatq_require_native_page_segment(v->ne[2] == static_cast<int64_t>(v_segments[i].token_end - v_segments[i].token_start), "QATQ segmented KQV contract found V token extent mismatch");
+    }
+}
+
+static bool qatq_segments_include_live_offloaded_page(
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & segments) {
+    for (const auto & segment : segments) {
+        if (segment.live_offloaded) {
+            return true;
+        }
+    }
+    return false;
+}
+
+static uint32_t qatq_segment_stream_count(
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & segments) {
+    uint32_t count = 0;
+    for (const auto & segment : segments) {
+        count = std::max<uint32_t>(count, segment.stream_index + 1);
+    }
+    return count;
+}
+
+static std::vector<llama_kv_cache::qatq_attention_page_segment> qatq_filter_segments_for_stream(
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & segments,
+        uint32_t stream_index) {
+    std::vector<llama_kv_cache::qatq_attention_page_segment> filtered;
+    for (const auto & segment : segments) {
+        if (segment.stream_index == stream_index) {
+            filtered.push_back(segment);
+        }
+    }
+    return filtered;
+}
+
+static bool qatq_segmented_kqv_backend_supported_dtype(ggml_type type) {
+    return type == GGML_TYPE_F16 || type == GGML_TYPE_BF16 || type == GGML_TYPE_F32;
+}
+
+static ggml_backend_t qatq_select_native_page_streaming_backend(
+        ggml_backend_sched_t sched,
+        ggml_backend_t       backend_cpu) {
+    qatq_require_native_page_segment(sched != nullptr, "QATQ backend-scheduled segmented KQV attention found a null scheduler");
+    const int n_backends = ggml_backend_sched_get_n_backends(sched);
+    for (int i = 0; i < n_backends; ++i) {
+        ggml_backend_t backend = ggml_backend_sched_get_backend(sched, i);
+        if (backend != nullptr && backend != backend_cpu) {
+            return backend;
+        }
+    }
+    throw std::runtime_error("QATQ backend-scheduled segmented KQV attention requires an accelerator backend");
+}
+
+static void qatq_validate_segmented_kqv_backend_contract(
+        ggml_tensor * q,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & k_segments,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & v_segments,
+        ggml_tensor * kq_b,
+        ggml_tensor * sinks,
+        ggml_tensor * v_mla) {
+    qatq_validate_segmented_kqv_contract(q, k_segments, v_segments, kq_b, sinks, v_mla);
+    qatq_require_native_page_segment(
+            k_segments.size() <= QATQ_SEGMENTED_KQV_BACKEND_MAX_SEGMENTS,
+            "QATQ segmented KQV backend contract exceeded max segment count");
+
+    const ggml_tensor * first_k = k_segments.front().tensor;
+    const int64_t n_stream = first_k->ne[3];
+    qatq_require_native_page_segment(n_stream > 0, "QATQ segmented KQV backend contract found invalid stream count");
+    qatq_require_native_page_segment(
+            q->ne[2] % n_stream == 0,
+            "QATQ segmented KQV backend contract requires query heads to divide streams");
+    qatq_require_native_page_segment(
+            qatq_segmented_kqv_backend_supported_dtype(first_k->type),
+            "QATQ segmented KQV backend contract supports only f16, bf16, and f32 K/V pages");
+
+    uint32_t total_tokens = 0;
+    for (size_t i = 0; i < k_segments.size(); ++i) {
+        const uint32_t page_tokens = k_segments[i].token_end - k_segments[i].token_start;
+        qatq_require_native_page_segment(
+                page_tokens <= QATQ_SEGMENTED_KQV_BACKEND_MAX_PAGE_TOKENS,
+                "QATQ segmented KQV backend contract exceeded max page tokens");
+        qatq_require_native_page_segment(
+                total_tokens <= QATQ_SEGMENTED_KQV_BACKEND_MAX_TOTAL_TOKENS - page_tokens,
+                "QATQ segmented KQV backend contract exceeded max total tokens");
+        total_tokens += page_tokens;
+    }
+}
+
+static ggml_tensor * qatq_build_segmented_kqv_page_pool(
+        ggml_context * ctx0,
+        ggml_cgraph * gf,
+        ggml_backend_sched_t sched,
+        ggml_backend_t target_backend,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & segments,
+        int64_t max_page_tokens,
+        uint64_t max_transient_pool_bytes,
+        uint64_t * transient_pool_bytes,
+        const char * kind) {
+    qatq_require_native_page_segment(ctx0 != nullptr, "QATQ page-pool builder found a null ggml context");
+    qatq_require_native_page_segment(gf != nullptr, "QATQ page-pool builder found a null graph");
+    qatq_require_native_page_segment(sched != nullptr, "QATQ page-pool builder found a null scheduler");
+    qatq_require_native_page_segment(target_backend != nullptr, "QATQ page-pool builder found a null target backend");
+    qatq_require_native_page_segment(kind != nullptr, "QATQ page-pool builder found a null segment kind");
+    qatq_require_native_page_segment(!segments.empty(), "QATQ page-pool builder found no page segments");
+    qatq_require_native_page_segment(max_page_tokens > 0, "QATQ page-pool builder found no page capacity");
+
+    ggml_tensor * first = segments.front().tensor;
+    qatq_require_native_page_segment(first != nullptr, "QATQ page-pool builder found a null first page tensor");
+    qatq_require_native_page_segment(first->ne[3] == 1, "QATQ page-pool builder supports only one stream");
+
+    const int64_t head_dim = first->ne[0];
+    const int64_t n_heads = first->ne[1];
+    ggml_tensor * pool = ggml_new_tensor_4d(ctx0, first->type, head_dim, n_heads, max_page_tokens, segments.size());
+    ggml_format_name(pool, "qatq_segmented_kqv_%s_retained_page_pool", kind);
+    const size_t pool_bytes = ggml_nbytes(pool);
+    qatq_require_native_page_segment(pool_bytes > 0, "QATQ backend-op transient page pool has zero bytes");
+    qatq_require_native_page_segment(
+            pool_bytes <= max_transient_pool_bytes,
+            "QATQ backend-op transient page pool byte budget exceeded");
+    if (transient_pool_bytes != nullptr) {
+        qatq_require_native_page_segment(
+                *transient_pool_bytes <= std::numeric_limits<uint64_t>::max() - static_cast<uint64_t>(pool_bytes),
+                "QATQ backend-op transient page pool byte accounting overflow");
+        *transient_pool_bytes += static_cast<uint64_t>(pool_bytes);
+    }
+    ggml_backend_sched_set_tensor_backend(sched, pool, target_backend);
+
+    int64_t expected_start = 0;
+    for (size_t i = 0; i < segments.size(); ++i) {
+        const auto & segment = segments[i];
+        ggml_tensor * page = segment.sync_tensor != nullptr ? segment.sync_tensor : segment.tensor;
+        qatq_require_native_page_segment(page != nullptr, "QATQ page-pool builder found a null page tensor");
+        qatq_require_native_page_segment(page->type == first->type, "QATQ page-pool builder found mixed page dtypes");
+        qatq_require_native_page_segment(page->ne[0] == head_dim, "QATQ page-pool builder found mixed head dimensions");
+        qatq_require_native_page_segment(page->ne[1] == n_heads, "QATQ page-pool builder found mixed head counts");
+        qatq_require_native_page_segment(page->ne[3] == 1, "QATQ page-pool builder found unsupported stream count");
+        qatq_require_native_page_segment(
+                static_cast<int64_t>(segment.token_start) == expected_start,
+                "QATQ page-pool builder found non-contiguous page start");
+
+        const int64_t page_tokens = static_cast<int64_t>(segment.token_end - segment.token_start);
+        qatq_require_native_page_segment(page_tokens > 0, "QATQ page-pool builder found an empty page");
+        qatq_require_native_page_segment(page_tokens <= max_page_tokens, "QATQ page-pool builder found page larger than pool capacity");
+        qatq_require_native_page_segment(page->ne[2] == page_tokens, "QATQ page-pool builder found token extent mismatch");
+
+        ggml_tensor * dst = ggml_view_4d(
+                ctx0,
+                pool,
+                head_dim,
+                n_heads,
+                page_tokens,
+                1,
+                pool->nb[1],
+                pool->nb[2],
+                pool->nb[3],
+                static_cast<size_t>(i) * pool->nb[3]);
+        ggml_format_name(dst, "qatq_segmented_kqv_%s_page_pool_view_%zu", kind, i);
+        ggml_backend_sched_set_tensor_backend(sched, dst, target_backend);
+
+        ggml_tensor * copy = ggml_cpy(ctx0, page, dst);
+        ggml_format_name(copy, "qatq_segmented_kqv_%s_page_pool_copy_%zu", kind, i);
+        ggml_backend_sched_set_tensor_backend(sched, copy, target_backend);
+        ggml_build_forward_expand(gf, copy);
+
+        expected_start += page_tokens;
+    }
+
+    return pool;
+}
+
+static ggml_tensor * qatq_require_segmented_kqv_retained_page_table(
+        ggml_context * ctx0,
+        ggml_cgraph * gf,
+        ggml_backend_sched_t sched,
+        ggml_backend_t target_backend,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & segments,
+        int64_t max_page_tokens,
+        const char * kind) {
+    qatq_require_native_page_segment(ctx0 != nullptr, "QATQ retained page-table path found a null ggml context");
+    qatq_require_native_page_segment(gf != nullptr, "QATQ retained page-table path found a null graph");
+    qatq_require_native_page_segment(sched != nullptr, "QATQ retained page-table path found a null scheduler");
+    qatq_require_native_page_segment(target_backend != nullptr, "QATQ retained page-table path found a null target backend");
+    qatq_require_native_page_segment(kind != nullptr, "QATQ retained page-table path found a null segment kind");
+    qatq_require_native_page_segment(!segments.empty(), "QATQ retained page-table path found no page segments");
+    qatq_require_native_page_segment(max_page_tokens > 0, "QATQ retained page-table path found no page capacity");
+
+    ggml_tensor * qatq_retained_page_table = segments.front().direct_pool;
+    qatq_require_native_page_segment(qatq_retained_page_table != nullptr, "QATQ backend-scheduled segmented KQV attention requires retained page-table K/V pools");
+    qatq_require_native_page_segment(qatq_retained_page_table->ne[2] == max_page_tokens, "QATQ retained page-table capacity mismatch");
+    qatq_require_native_page_segment(qatq_retained_page_table->ne[3] >= static_cast<int64_t>(segments.size()), "QATQ retained page-table has too few page slots");
+    ggml_backend_sched_set_tensor_backend(sched, qatq_retained_page_table, target_backend);
+
+    int64_t expected_start = 0;
+    for (size_t i = 0; i < segments.size(); ++i) {
+        const auto & segment = segments[i];
+        ggml_tensor * page = segment.tensor;
+        qatq_require_native_page_segment(page != nullptr, "QATQ retained page-table path found a null page tensor");
+        qatq_require_native_page_segment(segment.direct_pool == qatq_retained_page_table, "QATQ retained page-table path found mixed pools");
+        qatq_require_native_page_segment(segment.pool_index == i, "QATQ retained page-table path found non-linear pool indices");
+        const bool page_views_retained_pool = page->view_src == qatq_retained_page_table;
+        const bool page_views_shared_pool =
+            qatq_retained_page_table->view_src != nullptr &&
+            page->view_src == qatq_retained_page_table->view_src;
+        qatq_require_native_page_segment(
+                page_views_retained_pool || page_views_shared_pool,
+                "QATQ retained page-table path requires page views into the retained pool");
+        qatq_require_native_page_segment(page->type == qatq_retained_page_table->type, "QATQ retained page-table path found mixed page dtypes");
+        qatq_require_native_page_segment(page->ne[0] == qatq_retained_page_table->ne[0], "QATQ retained page-table path found mixed head dimensions");
+        qatq_require_native_page_segment(page->ne[1] == qatq_retained_page_table->ne[1], "QATQ retained page-table path found mixed head counts");
+        qatq_require_native_page_segment(page->ne[3] == 1, "QATQ retained page-table path found unsupported stream count");
+        qatq_require_native_page_segment(
+                static_cast<int64_t>(segment.token_start) == expected_start,
+                "QATQ retained page-table path found non-contiguous page start");
+
+        const int64_t page_tokens = static_cast<int64_t>(segment.token_end - segment.token_start);
+        qatq_require_native_page_segment(page_tokens > 0, "QATQ retained page-table path found an empty page");
+        qatq_require_native_page_segment(page_tokens <= max_page_tokens, "QATQ retained page-table path found page larger than pool capacity");
+        qatq_require_native_page_segment(page->ne[2] == page_tokens, "QATQ retained page-table path found token extent mismatch");
+        ggml_backend_sched_set_tensor_backend(sched, page, target_backend);
+
+        if (segment.sync_tensor != nullptr) {
+            ggml_backend_sched_set_tensor_backend(sched, segment.sync_tensor, target_backend);
+            ggml_build_forward_expand(gf, segment.sync_tensor);
+        }
+
+        expected_start += page_tokens;
+    }
+
+    return qatq_retained_page_table;
+}
+
+static ggml_tensor * qatq_prepare_segmented_kqv_backend_page_table(
+        ggml_context * ctx0,
+        ggml_cgraph * gf,
+        ggml_backend_sched_t sched,
+        ggml_backend_t target_backend,
+        const std::vector<llama_kv_cache::qatq_attention_page_segment> & segments,
+        int64_t max_page_tokens,
+        uint64_t max_transient_pool_bytes,
+        uint64_t * transient_pool_bytes,
+        const char * kind) {
+    qatq_require_native_page_segment(!segments.empty(), "QATQ segmented KQV page-table path found no page segments");
+
+    bool retained_table_available = segments.front().direct_pool != nullptr;
+    ggml_tensor * retained_table = segments.front().direct_pool;
+    for (size_t i = 0; i < segments.size(); ++i) {
+        const auto & segment = segments[i];
+        retained_table_available =
+            retained_table_available &&
+            segment.direct_pool == retained_table &&
+            segment.pool_index == i;
+    }
+
+    if (retained_table_available) {
+        return qatq_require_segmented_kqv_retained_page_table(
+                ctx0,
+                gf,
+                sched,
+                target_backend,
+                segments,
+                max_page_tokens,
+                kind);
+    }
+
+    return qatq_build_segmented_kqv_page_pool(
+            ctx0,
+            gf,
+            sched,
+            target_backend,
+            segments,
+            max_page_tokens,
+            max_transient_pool_bytes,
+            transient_pool_bytes,
+            kind);
+}
+
+static void qatq_native_page_streaming_contract(
+        ggml_context * ctx0,
+        const llama_kv_cache_context * mctx_cur,
+        ggml_tensor * q,
